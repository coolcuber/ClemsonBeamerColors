% This is intended to be used with the Madrid theme.
% I don't know how it would look with others.
%
% To use this theme, put this file in the same directory as your main source and add
% \usecolortheme{tiger} after \usetheme{Madrid} in your main file.



\mode<presentation>

\definecolor{ClemsonOrange}{RGB}{245,102,0}
\definecolor{GoalLine}{RGB}{255,255,255}
\definecolor{Regalia}{RGB}{82,45,128}

\setbeamercolor*{palette primary}{fg=white,bg=Regalia}
\setbeamercolor*{palette secondary}{fg=white,bg=ClemsonOrange}
\setbeamercolor*{palette tertiary}{fg=white,bg=Regalia!25!white}
\setbeamercolor*{palette quaternary}{fg=primary,bg=secondary!20!tertiary}

\setbeamercolor*{titlelike}{parent=palette primary}

\setbeamercolor{item}{fg=ClemsonOrange}

\setbeamercolor*{background canvas}{bg=Regalia!5!white}

\setbeamercolor{block title}{fg=white,bg=ClemsonOrange}
\setbeamercolor{block body}{bg=ClemsonOrange!20!white}

\setbeamercolor{block title example}{fg=white,bg=Regalia}
\setbeamercolor{block body example}{bg=Regalia!25!white}

\setbeamercolor{author in head/foot}{bg=Regalia}
\setbeamercolor{title in head/foot}{bg=ClemsonOrange}
\setbeamercolor{date in head/foot}{bg=Regalia}

\mode
<all>
